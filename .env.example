# Application
APP_ENV=production
APP_PORT=80
DOMAIN=localhost
BASE_URL=http://localhost

# Limits
MAX_IMAGES=50
MAX_VIDEOS=15
MAX_POSTS=50

MAX_VIDEO_SIZE_MB=100
MAX_VIDEO_DURATION_SECONDS=60
MAX_POST_LENGTH=10000

# Paths (absolute paths inside container or relative to project root)
UPLOAD_IMAGES_DIR=/app/uploads/images
UPLOAD_VIDEOS_DIR=/app/uploads/videos

# Database
# Ensure these match the DATABASE_URL below
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cutesite
# Connection string for the backend
DATABASE_URL=postgresql://postgres:postgres@db:5432/cutesite

# Security
SECRET_KEY=change_this_secret_key_in_production
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
